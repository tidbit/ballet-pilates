{
  "private": true,
  "name": "balletpilates",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "start": "if-env NODE_ENV=production && npm run -s serve || npm run -s dev",
    "build": "preact build --template src/template.html",
    "serve": "preact build --template src/template.html && preact serve --server superstatic",
    "dev": "preact watch --template src/template.html",
    "routes": "node process-routes.js",
    "lint": "eslint src"
  },
  "eslintConfig": {
    "extends": "eslint-config-synacor"
  },
  "eslintIgnore": [
    "build/*"
  ],
  "devDependencies": {
    "babel-plugin-transform-es2015-literals": "^6.22.0",
    "babel-plugin-transform-regenerator": "^6.26.0",
    "babel-plugin-transform-runtime": "^6.23.0",
    "eslint": "^4.5.0",
    "eslint-config-synacor": "^1.1.0",
    "if-env": "^1.0.0",
    "mobx": "^3.3.1",
    "mobx-react": "4.2.2",
    "node-sass": "^4.6.0",
    "postcss": "^6.0.14",
    "preact-cli": "^2.0.0",
    "prop-types": "^15.6.0",
    "sass-loader": "^6.0.6"
  },
  "dependencies": {
    "preact": "^8.2.1",
    "preact-compat": "^3.17.0",
    "preact-router": "^2.5.5",
    "react-apollo": "1.4.16",
    "superstatic": "^5.0.1"
  }
}
